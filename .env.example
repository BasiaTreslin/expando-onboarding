# Copy to .env.local (for dev) and set in Vercel (for production)

# REQUIRED in production — signs session cookies.
# Generate with: openssl rand -base64 32
# Min 32 chars. If not set, a development fallback is used (NOT SAFE for real users).
SESSION_SECRET=

# Notion API (for role-specific Resource Map, Phase 2)
NOTION_TOKEN=
